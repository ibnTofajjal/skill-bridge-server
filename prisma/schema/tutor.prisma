model TutorProfile {
  id           String  @id @default(uuid())
  bio          String?
  experience   String
  university   String
  pricePerHour Int
  major        String
  age          Int?
  cgpa         Float

  userId String
  user   User   @relation(fields: [userId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receivedReviews  Review[]       @relation("TutorReviews")
  receivedBookings Booking[]      @relation("TutorBookings")
  availabilities   Availability[]

  @@index([id])
  @@map("tutorProfiles")
}

enum SUBJECT_NAMES {
  HISTORY
  PHILOSOPHY
  ISLAMIC_HISTORY
  PHYSICS
  CHEMISTRY
  MATHEMATICS
  STATISTICS
  BIOLOGY
  PSYCHOLOGY
  ZOOLOGY
  ACCOUNTING
  FINANCE
  MARKETING
  MANAGEMENT
}

model Subject {
  id   String        @id @default(uuid())
  name SUBJECT_NAMES

  tutorProfiles TutorProfile[]

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([id, name])
  @@map("subjects")
}

model Review {
  id      Int     @id @default(autoincrement())
  rating  Float
  comment String?

  studentId      String
  tutorProfileId String

  student User         @relation("StudentReviews", fields: [studentId], references: [id])
  tutor   TutorProfile @relation("TutorReviews", fields: [tutorProfileId], references: [id])

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, tutorProfileId])
  @@index([studentId])
  @@index([tutorProfileId])
  @@index([rating])
  @@map("reviews")
}

enum BOOKING_STATUS {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Booking {
  id          Int            @id @default(autoincrement())
  sessionTime DateTime
  status      BOOKING_STATUS @default(PENDING)
  duration    Int

  studentId      String
  tutorProfileId String

  student User         @relation("StudentBookings", fields: [studentId], references: [id])
  tutor   TutorProfile @relation("TutorBookings", fields: [tutorProfileId], references: [id])

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("bookings")
}

enum DAY_OF_WEEK {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

model Availability {
  id             String       @id @default(uuid())
  tutorProfileId String
  tutorProfile   TutorProfile @relation(fields: [tutorProfileId], references: [id])
  dayOfWeek      DAY_OF_WEEK
  startTime      DateTime
  endTime        DateTime
  isBooked       Boolean

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
