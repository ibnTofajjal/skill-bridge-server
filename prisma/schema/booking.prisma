model Booking {
    id          String   @id @default(uuid())
    bookingDate DateTime @default(now())

    // student booking korbe
    studentId String
    student   User   @relation("StudentBooking", fields: [studentId], references: [id], onDelete: Cascade)

    tutorProfileId String
    tutorProfile   TutorProfile @relation("TutorBooking", fields: [tutorProfileId], references: [id], onDelete: Cascade)
}
