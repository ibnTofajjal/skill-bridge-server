enum WEEKDAY {
    MONDAY
    TUESDAY
    WEDNESDAY
    THURSDAY
    FRIDAY
    SATURDAY
    SUNDAY
}

model Availability {
    id        String  @id @default(uuid())
    day       WEEKDAY
    startTime String
    endTime   String

    tutorProfileId String
    tutorProfile   TutorProfile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
}
